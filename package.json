{
  "name": "claude-usage-dashboard",
  "version": "4.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "typegen": "next typegen",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx lib/db/seed.ts",
    "e2e:seed": "tsx scripts/seed-e2e.ts",
    "sync": "tsx scripts/sync.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshots": "tsx scripts/run-screenshot-capture.ts",
    "pages:build": "tsx scripts/build-pages-site.ts",
    "hooks:merge-conflicts": "tsx scripts/check-staged-merge-conflicts.ts",
    "prepare": "simple-git-hooks",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-switch": "^1.3.3",
    "@tanstack/react-query": "^5.101.2",
    "@trpc/client": "^11.18.0",
    "@trpc/next": "^11.18.0",
    "@trpc/react-query": "^11.9.0",
    "@trpc/server": "^11.9.0",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.9.2",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.8",
    "@yao-pkg/pkg": "^6.21.0",
    "autoprefixer": "^10.5.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10",
    "eslint-config-next": "16.2.10",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "8.5.16",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "brace-expansion": "2.0.3",
    "esbuild": "0.28.1",
    "postcss": "8.5.16"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,json,jsonc,css,md}": "biome check --write"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run hooks:merge-conflicts && npx lint-staged && npm run typecheck",
    "commit-msg": "npx commitlint --edit \"$1\""
  }
}
